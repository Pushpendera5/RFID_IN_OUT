# Application
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOOPBACK_HOST=127.0.0.1
APP_LOG_LEVEL=INFO
APP_FAIL_FAST=true
HIDE_INTERNAL_ERRORS=true

# CORS
CORS_ALLOW_ORIGINS=https://your-dashboard-domain.com
CORS_ALLOW_CREDENTIALS=true

# Database (MSSQL)
DB_DRIVER={ODBC Driver 17 for SQL Server}
DB_SERVER=YOUR_SQL_SERVER\\SQLEXPRESS
DB_PORT=
DB_NAME=jewellery_db
DB_TRUSTED_CONNECTION=yes
DB_USERNAME=
DB_PASSWORD=
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=yes
DB_TIMEOUT_SECONDS=5
SQLALCHEMY_DATABASE_URL=

# Reader ingest TCP
PORT_FIXED_READER=5001

# Embedded active reader
RFID_ACTIVE_ENABLED=true
RFID_ACTIVE_READER_HOST=169.254.4.161
RFID_ACTIVE_READER_PORT=5084
RFID_ACTIVE_ANTENNAS=1,2,3,4
RFID_ACTIVE_PUSH_URL=http://127.0.0.1:8000/rfid-read
RFID_ACTIVE_RECONNECT_DELAY=3
RFID_ACTIVE_REPORT_EVERY_N_TAGS=1
RFID_ACTIVE_REPORT_TIMEOUT_MS=0
RFID_ACTIVE_SESSION=0
RFID_ACTIVE_STALE_GRACE_SECONDS=1
RFID_ACTIVE_API_TIMEOUT_SECONDS=1
RFID_ACTIVE_DROP_STALE_REPORTS=false
RFID_ACTIVE_DEBUG=false
RFID_ACTIVE_PUSH_TOKEN=
RFID_ACTIVE_SINGLE_INSTANCE_LOCK=true
RFID_ACTIVE_LOCK_FILE_PATH=reader.lock

# Scan rules
SCAN_COOLDOWN_SECONDS=60
IN_REENTRY_COOLDOWN_SECONDS=60
OUT_BLOCK_AFTER_IN_SECONDS=60
ANTENNA_MAP=1:IN,2:OUT

# Auth/Security
COOKIE_NAME=session_id
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_PATH=/
SESSION_MAX_AGE_SECONDS=28800
PASSWORD_HASH_ITERATIONS=180000
SECRET_KEY=replace-with-long-random-secret
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_ROLE=admin
MAX_LOG_LIMIT=2000
